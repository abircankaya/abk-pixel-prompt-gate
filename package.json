{
  "name": "abk-enhance",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "bin": {
    "abk-enhance": "./src/cli.mjs"
  },
  "description": "MCP server that turns raw problem statements into structured Codex prompts and supports an approval flow.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abircankaya/abk-enhance.git"
  },
  "homepage": "https://github.com/abircankaya/abk-enhance#readme",
  "bugs": {
    "url": "https://github.com/abircankaya/abk-enhance/issues"
  },
  "keywords": [
    "codex",
    "mcp",
    "prompt",
    "agent",
    "approval-workflow"
  ],
  "files": [
    "src",
    "public",
    "docs",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "mcp-config.example.json"
  ],
  "scripts": {
    "start": "node src/index.mjs",
    "start:stdio": "node src/index.mjs",
    "start:http": "node src/httpServer.mjs",
    "cli": "node src/cli.mjs",
    "test": "node --test",
    "prepublishOnly": "npm test",
    "publish:dry-run": "npm publish --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "zod": "^4.1.5"
  }
}
